# .env.example – variáveis de ambiente para desenvolvimento
# Copie este arquivo para .env e ajuste os valores conforme necessário.

# Django
DEBUG=True
SECRET_KEY=django-insecure-CHANGE_ME
ALLOWED_HOSTS=localhost,127.0.0.1

# Banco de dados PostgreSQL
POSTGRES_USER=sigoq
POSTGRES_PASSWORD=sigoq_pass
POSTGRES_DB=sigoq_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis (se usado)
REDIS_HOST=redis
REDIS_PORT=6379